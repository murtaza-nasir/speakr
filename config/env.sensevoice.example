# -----------------------------------------------------------------------------
# Speakr Configuration: SenseVoice Local ASR (FunAudioLLM/SenseVoiceSmall)
#
# This configuration uses SenseVoice as the default local ASR engine.
# SenseVoice is a multilingual speech recognition model that supports:
# - Chinese, English, Japanese, Korean
# - Automatic language detection
# - Timestamps for each recognized segment
# - Emotion/speech act detection
#
# Model: FunAudioLLM/SenseVoiceSmall (default, ~2GB VRAM)
# Alternative: FunAudioLLM/SenseVoice (larger, ~4GB VRAM, more accurate)
#
# Requirements:
# - NVIDIA GPU with CUDA support (recommended, ~2GB+ VRAM)
# - CPU-only mode is supported but significantly slower
#
# Instructions:
# 1. Copy this file to a new file named .env
#    cp config/env.sensevoice.example .env
# 2. Fill in the required settings below.
# 3. SenseVoice does NOT support speaker diarization.
#    If you need diarization, consider using the ASR endpoint connector
#    with WhisperX instead (see env.whisperx.example).
# -----------------------------------------------------------------------------

# --- Text Generation Model (for summaries, titles, etc.) ---
TEXT_MODEL_BASE_URL=http://100.64.0.39:8000
TEXT_MODEL_API_KEY=
TEXT_MODEL_NAME=Qwen3.6-27B-UD-Q4_K_XL.gguf

# --- GPT-5 Specific Settings (only used with OpenAI API and GPT-5 models) ---
GPT5_REASONING_EFFORT=medium
GPT5_VERBOSITY=medium

# --- Chat Model Configuration (Optional) ---
# CHAT_MODEL_API_KEY=your_chat_api_key
# CHAT_MODEL_BASE_URL=https://openrouter.ai/api/v1
# CHAT_MODEL_NAME=openai/gpt-4o

# --- Transcription Service (SenseVoice Local ASR) ---
# Set explicit connector to SenseVoice
TRANSCRIPTION_CONNECTOR=sensevoice

# SenseVoice model name (HuggingFace model ID)
# Options:
#   FunAudioLLM/SenseVoiceSmall  - Default, fast, ~2GB VRAM
#   FunAudioLLM/SenseVoice       - Larger, more accurate, ~4GB VRAM
SENSEVOICE_MODEL=FunAudioLLM/SenseVoiceSmall

# Local model directory (takes priority over model download)
# When using docker-compose, this maps to the mounted model volume
# Example: SENSEVOICE_MODEL_DIR=/data/model
# For local development: SENSEVOICE_MODEL_DIR=/path/to/downloaded/model
SENSEVOICE_MODEL_DIR=/data/model

# Device for inference: cuda (recommended) or cpu
# CUDA requires an NVIDIA GPU with sufficient VRAM
SENSEVOICE_DEVICE=cuda

# Number of CPU threads for processing (when using CPU or for preprocessing)
SENSEVOICE_CPU_THREAD=4

# Skip model update check on startup (set to false to check for updates)
SENSEVOICE_DISABLE_UPDATE=true

# Directory to cache downloaded models (defaults to HF_HOME)
# SENSEVOICE_CACHE_DIR=/data/instance/huggingface

# Enable CT-Transformer punctuation restoration model
# When enabled, uses funasr's punc_ct-transformer to restore punctuation
# after transcription. Set to 'false' if you only want ITN-level punctuation.
# SENSEVOICE_USE_PUNCTUATION_MODEL=true

# --- Application Settings ---
ALLOW_REGISTRATION=false
REGISTRATION_ALLOWED_DOMAINS=
SUMMARY_MAX_TOKENS=8000
CHAT_MAX_TOKENS=5000

# Timezone for displaying dates and times in the UI
TIMEZONE="UTC"

# Set the logging level for the application.
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# --- Audio Compression ---
AUDIO_COMPRESS_UPLOADS=true
AUDIO_CODEC=mp3
AUDIO_BITRATE=128k

# --- Admin User (created on first run) ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Inquire Mode (AI search across all recordings) ---
ENABLE_INQUIRE_MODE=false

# --- Automated File Processing (Black Hole Directory) ---
ENABLE_AUTO_PROCESSING=false

# --- Automated Export Settings ---
ENABLE_AUTO_EXPORT=false
AUTO_EXPORT_DIR=/data/exports
AUTO_EXPORT_TRANSCRIPTION=true
AUTO_EXPORT_SUMMARY=true

# Processing mode: admin_only, user_directories, or single_user
AUTO_PROCESS_MODE=admin_only
AUTO_PROCESS_WATCH_DIR=/data/auto-process
AUTO_PROCESS_CHECK_INTERVAL=30
# AUTO_PROCESS_STABILITY_TIME=5
# AUTO_PROCESS_DEFAULT_USERNAME=admin

# --- Auto-Deletion & Retention Settings ---
ENABLE_AUTO_DELETION=false
GLOBAL_RETENTION_DAYS=90
DELETION_MODE=audio_only

# --- Permission-Based Deletion Controls ---
USERS_CAN_DELETE=true
# DELETE_ORPHANED_SPEAKERS=false

# --- Internal Sharing Settings ---
ENABLE_INTERNAL_SHARING=false
SHOW_USERNAMES_IN_UI=false

# --- Public Sharing Settings ---
ENABLE_PUBLIC_SHARING=true

# --- Video Retention ---
VIDEO_RETENTION=false

# --- Concurrent Uploads ---
MAX_CONCURRENT_UPLOADS=3

# --- Background Processing Queues ---
JOB_QUEUE_WORKERS=2
SUMMARY_QUEUE_WORKERS=2
JOB_MAX_RETRIES=3

# --- Docker Settings (rarely need to be changed) ---
SQLALCHEMY_DATABASE_URI=sqlite:////data/instance/transcriptions.db
UPLOAD_FOLDER=/data/uploads
